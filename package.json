{
  "name": "promptoon-workspace",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "dev:api": "pnpm --filter @promptoon/api dev",
    "migrate:api": "pnpm --filter @promptoon/api migrate"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
